# go-tasks-ui — Caddyfile
#
# Ships in the release tarball alongside the static bundle. Caddy provisions
# and renews TLS automatically via Let's Encrypt as long as the site address
# resolves to this host on ports 80 and 443.
#
# Usage:
#   1. Extract the tarball wherever you want it to live, e.g.
#        tar -xzf go-tasks-ui-<version>.tar.gz -C /var/www/go-tasks-ui --strip-components=1
#      The Caddyfile sits next to index.html / assets/ in that directory.
#   2. Set the env vars below and run from the same directory:
#        caddy run --config Caddyfile
#      (Or use a systemd unit / your process manager of choice.)
#
# Env vars:
#   SITE_ADDRESS   — hostname clients reach this UI on, e.g. tasks.example.com.
#                    Must be a real DNS name for ACME issuance.
#   API_UPSTREAM   — host:port of the go-tasks-api backend, e.g. api.internal:8080.
#   SITE_ROOT      — document root. Defaults to "." (the directory holding this
#                    Caddyfile). Override only if you keep the bundle elsewhere
#                    or are testing from the source repo (set to ./dist).
#   ACME_EMAIL     — contact email for the Let's Encrypt account.
#
# HTTP on :80 is reserved for two things only: the ACME HTTP-01 challenge
# (handled implicitly by Caddy on the issuance path) and a permanent 308
# redirect to the HTTPS site below. There is no plain-HTTP application.
#
# Homeserver / LAN-only deployments (.local hostnames, IP-only access, or any
# host Let's Encrypt can't reach over port 80): replace the `tls { ... }`
# block with `tls internal` and delete the `http://{$SITE_ADDRESS}` redir
# block above. Caddy will issue from its local CA instead of ACME — run
# `caddy trust` on each client device to install the local root cert. See
# the README "Releases" section for the full diff.

{
	email {$ACME_EMAIL}
	# Force the modern TLS profile. ACME defaults to Let's Encrypt.
	servers {
		protocols h1 h2 h3
	}
}

# Explicit HTTP listener that 308-redirects every request to HTTPS. Caddy
# would do this automatically for any hostname site, but pinning the redirect
# in config keeps the behaviour visible and audit-friendly.
http://{$SITE_ADDRESS} {
	redir https://{host}{uri} permanent
}

{$SITE_ADDRESS} {
	root * {$SITE_ROOT:.}
	encode zstd gzip

	# TLS is on by default for any site address with a hostname; this block
	# pins the minimum version so we never downgrade to TLS 1.1.
	tls {
		protocols tls1.2 tls1.3
	}

	# Security headers. HSTS is only safe once you're sure HTTPS is sticking —
	# it's set with a long max-age + preload because this site is HTTPS-only.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "geolocation=(), microphone=(), camera=()"
		# Don't leak the Caddy version.
		-Server
	}

	# Reverse-proxy API + health to the backend. Header rewrites mirror what
	# the previous nginx config did so the backend sees the original client.
	@api path /api/* /health
	handle @api {
		reverse_proxy {$API_UPSTREAM} {
			header_up Host               {host}
			header_up X-Real-IP          {remote_host}
			header_up X-Forwarded-For    {remote_host}
			header_up X-Forwarded-Proto  {scheme}
		}
	}

	# Long-lived caching for fingerprinted assets emitted by Vite.
	@assets path *.js *.css *.woff *.woff2 *.png *.svg *.ico
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server {
			# Serve the static bundle but don't ever ship the Caddyfile itself —
			# it sits in the same directory now that the tarball is flat.
			hide Caddyfile
		}
	}

	# SPA fallback — anything that isn't a real file falls through to index.html.
	handle {
		header Cache-Control "no-store, no-cache, must-revalidate"
		try_files {path} /index.html
		file_server {
			hide Caddyfile
		}
	}
}
